# Database
DATABASE_URL=sqlite+aiosqlite:///./data/ledgerlens.db
DATA_DIR=./data

# LLM (Ollama default)
LLM_BASE_URL=http://127.0.0.1:11434/v1
LLM_MODEL=llama3.2
LLM_API_KEY=
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=1

# Session secret & encryption key — CHANGE IN PRODUCTION
# This key is used for both session signing and API key encryption (Fernet).
# If you rotate this key, all stored API keys must be re-encrypted.
SECRET_KEY=change-me-to-a-random-string

# Server
HOST=0.0.0.0
PORT=8000

# Celery / Redis
CELERY_BROKER_URL=redis://localhost:6379/0
TASK_SOFT_TIME_LIMIT=300
TASK_HARD_TIME_LIMIT=360

# Google CSE (optional, for product images)
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_CX=

# Rate limiting (per IP)
RATE_LIMIT_LOGIN_MAX=5
RATE_LIMIT_LOGIN_WINDOW_SECONDS=900
RATE_LIMIT_REGISTER_MAX=3
RATE_LIMIT_REGISTER_WINDOW_SECONDS=900

# Fuzzy matching thresholds
FUZZY_AUTO_LINK_THRESHOLD=85
FUZZY_SUGGEST_THRESHOLD=60

# Tesseract
TESSERACT_LANG=eng
TESSERACT_PSM=6
TESSERACT_DPI=300
